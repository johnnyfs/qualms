# Required for the editor-mode `prompt:` coauthor command when using Anthropic.
ANTHROPIC_API_KEY=

# Required when QUALMS_COAUTHOR_MODEL starts with openai: or openai-responses:.
OPENAI_API_KEY=

# Pydantic AI model identifier. Override as Anthropic model names change.
QUALMS_COAUTHOR_MODEL=anthropic:claude-opus-4-1-20250805
# OpenAI option, using the Responses API for tool-heavy editor work:
# QUALMS_COAUTHOR_MODEL=openai-responses:gpt-5.5

# Local guardrail for tool-driven edit loops.
QUALMS_COAUTHOR_MAX_TOOL_CALLS=40
